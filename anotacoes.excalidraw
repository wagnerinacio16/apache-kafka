    {
      "id": "ZIvKKZr9qikl0FBDaZIbo",
      "type": "text",
      "x": -665.381240663075,
      "y": 1906.08097076416,
      "width": 565.9595947265625,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aq",
      "roundness": null,
      "seed": 425101278,
      "version": 598,
      "versionNonce": 1033627614,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "7xIZvsk_dxRBxADluqi_K",
          "type": "arrow"
        }
      ],
      "updated": 1777423108992,
      "link": null,
      "locked": false,
      "text": "Chaves são utilizadas ára definir através de hash \npara qual participação sua mensagem será enviada\n\nCaso nenhuma chave seja informada, os dados serão\ndistribuidos aleatoriamente em diferentes particoes\naleatoriamente em diferentes particeoes.\n\nSem chave, não é possível garantir a ordem das mensagens\nem sua entrega",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Chaves são utilizadas ára definir através de hash \npara qual participação sua mensagem será enviada\n\nCaso nenhuma chave seja informada, os dados serão\ndistribuidos aleatoriamente em diferentes particoes\naleatoriamente em diferentes particeoes.\n\nSem chave, não é possível garantir a ordem das mensagens\nem sua entrega",
      "autoResize": true,
      "lineHeight": 1.25
    },
